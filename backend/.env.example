APP_NAME=LabNote API
APP_ENV=local
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8110
APP_SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
SYSTEM_ADMIN_PASSWORD=change-this-admin-password

# [DATABASE CONFIG]
DB=sqlite
DB_NAME=storage/labnote.db

STORAGE_ROOT=./storage

